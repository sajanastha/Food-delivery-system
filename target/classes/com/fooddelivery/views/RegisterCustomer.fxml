<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.fooddelivery.RegisterCustomerController"
           style="-fx-background-color: #1C3A5E;">

    <VBox alignment="CENTER" spacing="0" maxWidth="440">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #1D4ED8;
                     -fx-padding: 24 40 18 40;
                     -fx-background-radius: 14 14 0 0;">
            <Label text="🧑‍💼  Customer Registration"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
            <Label text="Create your customer account"
                   style="-fx-font-size: 11px; -fx-text-fill: #BFDBFE;"/>
        </VBox>

        <!-- Form -->
        <VBox spacing="9"
              style="-fx-background-color: white;
                     -fx-padding: 24 36 22 36;
                     -fx-background-radius: 0 0 14 14;">

            <Label text="Full Name *"
                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                          -fx-text-fill: #374151;"/>
            <TextField fx:id="fullNameField"
                       promptText="Your full name"
                       style="-fx-border-color: #D1D5DB; -fx-border-radius: 7;
                              -fx-background-radius: 7; -fx-padding: 8 10;"/>

            <Label text="Email Address *"
                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                          -fx-text-fill: #374151;"/>
            <TextField fx:id="emailField"
                       promptText="you@example.com"
                       style="-fx-border-color: #D1D5DB; -fx-border-radius: 7;
                              -fx-background-radius: 7; -fx-padding: 8 10;"/>

            <HBox spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Password *"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Min 4 characters"
                                   style="-fx-border-color: #D1D5DB;
                                          -fx-border-radius: 7;
                                          -fx-background-radius: 7;
                                          -fx-padding: 8 10;"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Confirm Password *"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;"/>
                    <PasswordField fx:id="confirmField"
                                   promptText="Repeat password"
                                   style="-fx-border-color: #D1D5DB;
                                          -fx-border-radius: 7;
                                          -fx-background-radius: 7;
                                          -fx-padding: 8 10;"/>
                </VBox>
            </HBox>

            <Label text="Phone"
                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                          -fx-text-fill: #374151;"/>
            <TextField fx:id="phoneField"
                       promptText="Phone number"
                       style="-fx-border-color: #D1D5DB;
                              -fx-border-radius: 7;
                              -fx-background-radius: 7;
                              -fx-padding: 8 10;"/>

            <!-- Status labels -->
            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"
                   wrapText="true"/>
            <Label fx:id="successLabel" text=""
                   style="-fx-text-fill: #16A34A; -fx-font-size: 11px;"
                   wrapText="true"/>

            <!-- Register button -->
            <Button text="Create Customer Account"
                    onAction="#handleRegister"
                    maxWidth="Infinity" prefHeight="40"
                    style="-fx-background-color: #1D4ED8;
                           -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-cursor: hand;"/>

            <!-- Navigation -->
            <HBox spacing="10" alignment="CENTER">
                <Button text="← Back"
                        onAction="#handleBack"
                        style="-fx-background-color: #F1F5F9;
                               -fx-border-color: #CBD5E0;
                               -fx-border-radius: 7; -fx-background-radius: 7;
                               -fx-text-fill: #475569; -fx-cursor: hand;
                               -fx-padding: 7 20;"/>
                <Button text="Already have an account? Login"
                        onAction="#handleBackToLogin"
                        style="-fx-background-color: transparent;
                               -fx-border-color: transparent;
                               -fx-text-fill: #D4600A; -fx-font-weight: bold;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
