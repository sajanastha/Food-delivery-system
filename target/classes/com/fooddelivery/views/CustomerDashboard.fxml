<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fooddelivery.CustomerDashboardController"
            prefWidth="960" prefHeight="680"
            style="-fx-background-color: #F8FAFC;">
    <fx:define>
        <ToggleGroup fx:id="searchTypeGroup"/>
    </fx:define>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1C3A5E; -fx-padding: 12 24;">
            <Label text="QuickBite"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Pane HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <StackPane>
            <ScrollPane fx:id="homePage" fitToWidth="true"
                        style="-fx-background: #F8FAFC; -fx-background-color: #F8FAFC;">
                <VBox spacing="0">
                    <VBox alignment="CENTER" spacing="8"
                          style="-fx-background-color: #1C3A5E; -fx-padding: 28 24 24 24;">
                        <Label text="What are you craving today?"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Order from the best restaurants near you"
                               style="-fx-font-size: 12px; -fx-text-fill: #93C5FD;"/>
                    </VBox>
                    <VBox spacing="24" style="-fx-padding: 22 20;">
                        <VBox spacing="12">
                            <Label text="Most Popular Restaurants Today"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1C3A5E;"/>
                            <FlowPane fx:id="popularRestaurantsPane" hgap="14" vgap="14"/>
                            <Label fx:id="noPopularRestLabel" text="" visible="false"
                                   style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px;"/>
                        </VBox>
                        <Separator/>
                        <VBox spacing="12">
                            <Label text="Most Ordered Food Right Now"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1C3A5E;"/>
                            <FlowPane fx:id="popularFoodPane" hgap="14" vgap="14"/>
                            <Label fx:id="noPopularFoodLabel" text="" visible="false"
                                   style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px;"/>
                        </VBox>
                    </VBox>
                </VBox>
            </ScrollPane>

            <VBox fx:id="searchPage" spacing="0" visible="false"
                  style="-fx-background-color: #F8FAFC;">
                <VBox spacing="12" style="-fx-background-color: white;
                                          -fx-border-color: transparent transparent #E5E7EB transparent;
                                          -fx-padding: 18 20 14 20;">
                    <Label text="Search" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1C3A5E;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField"
                                   promptText="Search restaurants or food..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-border-color: #CBD5E0; -fx-border-radius: 20;
                                          -fx-background-radius: 20; -fx-padding: 10 16;
                                          -fx-font-size: 13px;"/>
                        <Button text="Search" onAction="#handleSearch"
                                style="-fx-background-color: #FF7518; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 20;
                                       -fx-cursor: hand; -fx-padding: 10 20;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Search for:" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                        <RadioButton fx:id="searchRestaurantRadio" text="Restaurants"
                                     selected="true" toggleGroup="$searchTypeGroup"
                                     style="-fx-font-size: 12px;"/>
                        <RadioButton fx:id="searchFoodRadio" text="Food Items"
                                     toggleGroup="$searchTypeGroup"
                                     style="-fx-font-size: 12px;"/>
                    </HBox>
                </VBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: #F8FAFC; -fx-background-color: #F8FAFC;">
                    <VBox spacing="14" style="-fx-padding: 18;">
                        <Label fx:id="searchStatusLabel" text="Type something to search..."
                               style="-fx-text-fill: #9CA3AF; -fx-font-size: 13px;"/>
                        <Label fx:id="notFoundLabel" text="SORRY, NOT FOUND!"
                               visible="false"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;
                                      -fx-text-fill: #DC2626; -fx-alignment: center;"/>
                        <FlowPane fx:id="searchResultsPane" hgap="14" vgap="14"/>
                    </VBox>
                </ScrollPane>
            </VBox>

            <VBox fx:id="cartPage" spacing="0" visible="false"
                  style="-fx-background-color: #F8FAFC;">
                <VBox style="-fx-padding: 20;">
                    <Label text="My Cart"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;
                                  -fx-text-fill: #1C3A5E; -fx-padding: 0 0 14 0;"/>
                    <HBox spacing="16" VBox.vgrow="ALWAYS">
                        <VBox spacing="8" prefWidth="380">
                            <Label text="Items"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <ListView fx:id="cartListView" prefHeight="300"
                                      style="-fx-border-color: #E5E7EB; -fx-border-radius: 8;"/>
                            <Button text="Remove Selected" onAction="#handleRemoveFromCart"
                                    maxWidth="Infinity" prefHeight="36"
                                    style="-fx-background-color: #DC2626; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </VBox>
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Label text="Order Summary"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextArea fx:id="pricingArea" prefHeight="200" editable="false"
                                      style="-fx-font-family: monospace; -fx-font-size: 12px;
                                             -fx-border-color: #E5E7EB; -fx-border-radius: 8;"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Delivery Address:"
                                       style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <TextField fx:id="addressField"
                                           promptText="Enter delivery address"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                                  -fx-background-radius: 8; -fx-padding: 8 10;"/>
                            </HBox>
                            <Button text="Place Order" onAction="#handlePlaceOrder"
                                    maxWidth="Infinity" prefHeight="42"
                                    style="-fx-background-color: #15803D; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-font-size: 14px;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Label fx:id="cartStatus" text=""
                                   style="-fx-font-size: 12px;" wrapText="true"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <VBox fx:id="historyPage" spacing="0" visible="false"
                  style="-fx-background-color: #F8FAFC;">
                <VBox style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 14 0;">
                        <Label text="Order History"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;
                                      -fx-text-fill: #1C3A5E;" HBox.hgrow="ALWAYS"/>
                        <Button text="Refresh" onAction="#handleRefreshHistory"
                                style="-fx-background-color: #1C3A5E; -fx-text-fill: white;
                                       -fx-background-radius: 7; -fx-cursor: hand; -fx-padding: 7 14;"/>
                    </HBox>
                    <VBox fx:id="emptyHistoryBox" alignment="CENTER" spacing="16"
                          visible="false" VBox.vgrow="ALWAYS" style="-fx-padding: 60 0;">
                        <Label text="Start your very first order!"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label text="Explore restaurants and order something delicious."
                               style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                        <Button text="Browse &amp; Order Now" onAction="#goToSearch"
                                prefHeight="42" prefWidth="220"
                                style="-fx-background-color: #FF7A00; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 13px;
                                       -fx-background-radius: 12; -fx-cursor: hand;"/>
                    </VBox>
                    <ListView fx:id="historyListView" VBox.vgrow="ALWAYS"
                              style="-fx-border-color: #E5E7EB; -fx-border-radius: 8;"/>
                </VBox>
            </VBox>

            <ScrollPane fx:id="profilePage" fitToWidth="true" visible="false"
                        style="-fx-background: #F8FAFC; -fx-background-color: #F8FAFC;">
                <VBox spacing="18" style="-fx-padding: 24;">
                    <Label text="My Profile"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1C3A5E;"/>
                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-border-color: #E5E7EB;
                                 -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 18 20;">
                        <Label text="PERSONAL INFORMATION"
                               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF;"/>
                        <HBox spacing="14">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Full Name"
                                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <TextField fx:id="profileNameField"
                                           style="-fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                                  -fx-background-radius: 8; -fx-padding: 9 12;"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Phone"
                                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <TextField fx:id="profilePhoneField"
                                           promptText="Your phone number"
                                           style="-fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                                  -fx-background-radius: 8; -fx-padding: 9 12;"/>
                            </VBox>
                        </HBox>
                        <Button text="Save Name &amp; Phone" onAction="#handleSaveName"
                                prefHeight="36"
                                style="-fx-background-color: #1C3A5E; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-padding: 0 20;"/>
                        <Label fx:id="nameStatus" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #15803D;"/>
                    </VBox>
                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-border-color: #E5E7EB;
                                 -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 18 20;">
                        <Label text="CHANGE EMAIL"
                               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF;"/>
                        <VBox spacing="5">
                            <Label text="Current Email (read-only)"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="currentEmailDisplay" editable="false"
                                       style="-fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                              -fx-background-radius: 8; -fx-padding: 9 12;
                                              -fx-background-color: #F9FAFB;"/>
                        </VBox>
                        <HBox spacing="14">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="New Email"
                                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <TextField fx:id="newEmailField" promptText="new@email.com"
                                           style="-fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                                  -fx-background-radius: 8; -fx-padding: 9 12;"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Current Password (to confirm)"
                                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <PasswordField fx:id="emailConfirmPassField"
                                               promptText="Your current password"
                                               style="-fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                                      -fx-background-radius: 8; -fx-padding: 9 12;"/>
                            </VBox>
                        </HBox>
                        <Button text="Update Email" onAction="#handleChangeEmail"
                                prefHeight="36"
                                style="-fx-background-color: #1D4ED8; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-padding: 0 20;"/>
                        <Label fx:id="emailStatus" text=""
                               style="-fx-font-size: 11px;" wrapText="true"/>
                    </VBox>
                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-border-color: #E5E7EB;
                                 -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 18 20;">
                        <Label text="CHANGE PASSWORD"
                               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF;"/>
                        <HBox spacing="14">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Current Password"
                                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <PasswordField fx:id="currentPassField" promptText="Current password"
                                               style="-fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                                      -fx-background-radius: 8; -fx-padding: 9 12;"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="New Password"
                                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <PasswordField fx:id="newPassField" promptText="New password (min 4)"
                                               style="-fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                                      -fx-background-radius: 8; -fx-padding: 9 12;"/>
                            </VBox>
                        </HBox>
                        <Button text="Change Password" onAction="#handleChangePassword"
                                prefHeight="36"
                                style="-fx-background-color: #7C3AED; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-padding: 0 20;"/>
                        <Label fx:id="passStatus" text=""
                               style="-fx-font-size: 11px;" wrapText="true"/>
                    </VBox>
                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-border-color: #E5E7EB;
                                 -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 18 20;">
                        <Label text="ACCOUNT"
                               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF;"/>
                        <Label fx:id="profileWelcomeLabel" text=""
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1C3A5E;"/>
                        <Button text="Logout" onAction="#handleLogout"
                                prefHeight="40" maxWidth="Infinity"
                                style="-fx-background-color: #DC2626; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 10;
                                       -fx-cursor: hand;"/>
                    </VBox>
                </VBox>
            </ScrollPane>

            <ScrollPane fx:id="feedbackPage" fitToWidth="true" visible="false"
                        style="-fx-background: #F8FAFC; -fx-background-color: #F8FAFC;">
                <VBox spacing="16" style="-fx-padding: 24;">
                    <Label text="Feedback History"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1C3A5E;"/>
                    <Label text="Your ordered food items are shown here under each restaurant. You can add feedback for any item that does not have one yet."
                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                    <VBox fx:id="emptyFeedbackBox" alignment="CENTER" spacing="14" visible="false"
                          style="-fx-background-color: white; -fx-border-color: #E5E7EB;
                                 -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 40 24;">
                        <Label text="No orders yet."
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label text="Order from a restaurant first, then you will be able to see and add feedback here."
                               style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                        <Button text="Browse &amp; Order Now" onAction="#goToSearch"
                                prefHeight="38" prefWidth="240"
                                style="-fx-background-color: #FF7A00; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 14px;
                                       -fx-background-radius: 12; -fx-cursor: hand;"/>
                    </VBox>
                    <VBox fx:id="feedbackItemsBox" spacing="14"/>
                    <Label fx:id="feedbackPageStatus" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" wrapText="true"/>
                </VBox>
            </ScrollPane>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="0"
              style="-fx-background-color: white;
                     -fx-border-color: #E5E7EB transparent transparent transparent;
                     -fx-border-width: 1;">
            <Button fx:id="navHome" text="Home"
                    onAction="#navToHome"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                    prefHeight="62"
                    style="-fx-background-color: white;
                           -fx-text-fill: #FF7518;
                           -fx-font-size: 11px; -fx-font-weight: bold;
                           -fx-background-radius: 0; -fx-cursor: hand;
                           -fx-border-color: transparent;"/>
            <Button fx:id="navSearch" text="Search"
                    onAction="#navToSearch"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                    prefHeight="62"
                    style="-fx-background-color: white;
                           -fx-text-fill: #6B7280;
                           -fx-font-size: 11px; -fx-font-weight: bold;
                           -fx-background-radius: 0; -fx-cursor: hand;
                           -fx-border-color: transparent;"/>
            <Button fx:id="navHistory" text="Orders"
                    onAction="#navToHistory"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                    prefHeight="62"
                    style="-fx-background-color: white;
                           -fx-text-fill: #6B7280;
                           -fx-font-size: 11px; -fx-font-weight: bold;
                           -fx-background-radius: 0; -fx-cursor: hand;
                           -fx-border-color: transparent;"/>
            <Button fx:id="navProfile" text="Profile"
                    onAction="#navToProfile"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                    prefHeight="62"
                    style="-fx-background-color: white;
                           -fx-text-fill: #6B7280;
                           -fx-font-size: 11px; -fx-font-weight: bold;
                           -fx-background-radius: 0; -fx-cursor: hand;
                           -fx-border-color: transparent;"/>
            <Button fx:id="navFeedback" text="Feedback"
                    onAction="#navToFeedback"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                    prefHeight="62"
                    style="-fx-background-color: white;
                           -fx-text-fill: #6B7280;
                           -fx-font-size: 11px; -fx-font-weight: bold;
                           -fx-background-radius: 0; -fx-cursor: hand;
                           -fx-border-color: transparent;"/>
        </HBox>
    </bottom>
</BorderPane>
