<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fooddelivery.CustomerDashboardController"
            prefWidth="1020" prefHeight="700"
            style="-fx-background-color: #F4F5F7;">

    <!-- ── TOP NAV ─────────────────────────────────────────────────────── -->
    <top>
        <VBox style="-fx-background-color: white;
                     -fx-border-color: #EBEBEB;
                     -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),4,0,0,2);">
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-padding: 12 24;">
                <Label text="🍴 QuickBite"
                       style="-fx-font-size: 19px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #FF6B35;"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="welcomeLabel"
                       style="-fx-text-fill: #555;
                              -fx-font-size: 13px;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="My Profile"
                        onAction="#showProfile"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;
                               -fx-border-color: #DDD;
                               -fx-border-radius: 6;
                               -fx-background-radius: 6;
                               -fx-padding: 5 14;"/>
                <Button text="Logout"
                        onAction="#handleLogout"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #999;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;
                               -fx-border-color: #DDD;
                               -fx-border-radius: 6;
                               -fx-background-radius: 6;
                               -fx-padding: 5 14;"/>
            </HBox>
            <!-- Tab nav -->
            <HBox style="-fx-padding: 0 24 0 24;">
                <Button fx:id="tabOrder" text="Order Food"
                        onAction="#showOrderTab"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #FF6B35;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-padding: 9 18;
                               -fx-cursor: hand;
                               -fx-border-color: transparent transparent #FF6B35 transparent;
                               -fx-border-width: 0 0 2.5 0;"/>
                <Button fx:id="tabHistory" text="Order History"
                        onAction="#showHistoryTab"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #888;
                               -fx-font-size: 13px;
                               -fx-padding: 9 18;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── MAIN CONTENT ────────────────────────────────────────────────── -->
    <center>
        <StackPane>

            <!-- ===== ORDER FOOD PANEL ===== -->
            <BorderPane fx:id="orderPanel">
                <!-- Search bar -->
                <top>
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-padding: 14 20 10 20;
                                 -fx-background-color: white;
                                 -fx-border-color: #EBEBEB;
                                 -fx-border-width: 0 0 1 0;">
                        <TextField fx:id="searchField"
                                   promptText="Search restaurants or dishes..."
                                   prefWidth="320"
                                   style="-fx-border-color: #E0E0E0;
                                          -fx-border-radius: 20;
                                          -fx-background-radius: 20;
                                          -fx-padding: 7 16;
                                          -fx-font-size: 13px;
                                          -fx-background-color: #F7F7F7;"/>
                        <Button text="Search"
                                onAction="#handleSearch"
                                style="-fx-background-color: #FF6B35;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 20;
                                       -fx-padding: 7 20;
                                       -fx-font-size: 13px;
                                       -fx-cursor: hand;"/>
                        <Button text="All"
                                onAction="#handleShowAll"
                                style="-fx-background-color: #F0F0F0;
                                       -fx-text-fill: #555;
                                       -fx-background-radius: 20;
                                       -fx-padding: 7 14;
                                       -fx-font-size: 13px;
                                       -fx-cursor: hand;"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Label fx:id="browseStatus"
                               style="-fx-text-fill: #999;
                                      -fx-font-size: 12px;"/>
                    </HBox>
                </top>

                <!-- Two-column: restaurant list | menu + cart actions -->
                <center>
                    <HBox>
                        <!-- Restaurant list (left) -->
                        <VBox prefWidth="300"
                              style="-fx-background-color: white;
                                     -fx-border-color: #EBEBEB;
                                     -fx-border-width: 0 1 0 0;">
                            <Label text="Restaurants"
                                   style="-fx-padding: 14 18 8 18;
                                          -fx-font-size: 12px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #999;"/>
                            <ListView fx:id="restaurantListView"
                                      VBox.vgrow="ALWAYS"
                                      onMouseClicked="#handleRestaurantSelected"
                                      style="-fx-border-color: transparent;
                                             -fx-font-size: 13px;"/>
                            <Label fx:id="restaurantInfoLabel"
                                   text="Select a restaurant"
                                   wrapText="true"
                                   style="-fx-text-fill: #AAA;
                                          -fx-font-size: 11px;
                                          -fx-padding: 6 14 10 14;"/>
                        </VBox>

                        <!-- Menu + actions (right) -->
                        <VBox HBox.hgrow="ALWAYS">
                            <!-- Menu header -->
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 14 18 8 18;
                                         -fx-background-color: white;
                                         -fx-border-color: #EBEBEB;
                                         -fx-border-width: 0 0 1 0;">
                                <Label fx:id="menuTitleLabel"
                                       text="Select a restaurant to view menu"
                                       style="-fx-font-size: 14px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #333;"/>
                                <Pane HBox.hgrow="ALWAYS"/>
                                <Label fx:id="cartCountLabel"
                                       text=""
                                       style="-fx-font-size: 12px;
                                              -fx-text-fill: #FF6B35;
                                              -fx-font-weight: bold;"/>
                            </HBox>

                            <!-- Menu list -->
                            <ListView fx:id="menuListView"
                                      VBox.vgrow="ALWAYS"
                                      style="-fx-border-color: transparent;
                                             -fx-font-size: 13px;
                                             -fx-padding: 0 10;
                                             -fx-background-color: #F4F5F7;"/>

                            <!-- Bottom action bar -->
                            <HBox alignment="CENTER_RIGHT" spacing="10"
                                  style="-fx-padding: 12 18;
                                         -fx-background-color: white;
                                         -fx-border-color: #EBEBEB;
                                         -fx-border-width: 1 0 0 0;">
                                <Label fx:id="selectedItemLabel"
                                       text=""
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-text-fill: #555;
                                              -fx-font-size: 12px;"/>
                                <Button text="View Cart"
                                        onAction="#handleViewCart"
                                        style="-fx-background-color: white;
                                               -fx-text-fill: #FF6B35;
                                               -fx-border-color: #FF6B35;
                                               -fx-border-radius: 8;
                                               -fx-background-radius: 8;
                                               -fx-font-size: 13px;
                                               -fx-font-weight: bold;
                                               -fx-padding: 9 20;
                                               -fx-cursor: hand;"/>
                                <Button text="+ Add to Cart"
                                        onAction="#handleAddToCart"
                                        style="-fx-background-color: #FF6B35;
                                               -fx-text-fill: white;
                                               -fx-background-radius: 8;
                                               -fx-font-size: 13px;
                                               -fx-font-weight: bold;
                                               -fx-padding: 9 20;
                                               -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </center>
            </BorderPane>

            <!-- ===== ORDER HISTORY PANEL ===== -->
            <VBox fx:id="historyPanel" spacing="0" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 16 22 12 22;
                             -fx-background-color: white;
                             -fx-border-color: #EBEBEB;
                             -fx-border-width: 0 0 1 0;">
                    <VBox spacing="2">
                        <Label text="Your Orders"
                               style="-fx-font-size: 16px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #222;"/>
                        <Label text="Track your past and current orders"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #999;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh"
                            onAction="#handleRefreshHistory"
                            style="-fx-background-color: #F0F0F0;
                                   -fx-text-fill: #555;
                                   -fx-background-radius: 8;
                                   -fx-padding: 7 16;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;"/>
                    <Button text="Leave Feedback"
                            onAction="#handleLeaveFeedback"
                            style="-fx-background-color: #FF6B35;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-padding: 7 16;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;
                                   -fx-cursor: hand;"/>
                </HBox>
                <ListView fx:id="historyListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-border-color: transparent;
                                 -fx-font-size: 13px;
                                 -fx-padding: 10 18;"/>
            </VBox>

            <!-- ===== PROFILE PANEL ===== -->
            <VBox fx:id="profilePanel" spacing="0" visible="false">
                <HBox alignment="CENTER_LEFT"
                      style="-fx-padding: 16 22 12 22;
                             -fx-background-color: white;
                             -fx-border-color: #EBEBEB;
                             -fx-border-width: 0 0 1 0;">
                    <VBox spacing="2">
                        <Label text="My Profile"
                               style="-fx-font-size: 16px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #222;"/>
                        <Label text="Your account details"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #999;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="← Back"
                            onAction="#showOrderTab"
                            style="-fx-background-color: #F0F0F0;
                                   -fx-text-fill: #555;
                                   -fx-background-radius: 8;
                                   -fx-padding: 7 16;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;"/>
                </HBox>
                <VBox spacing="0"
                      style="-fx-padding: 24;
                             -fx-background-color: #F4F5F7;">
                    <VBox spacing="16"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 28;
                                 -fx-border-color: #EBEBEB;
                                 -fx-border-radius: 12;
                                 -fx-max-width: 480;">
                        <Label text="Account Information"
                               style="-fx-font-size: 14px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #333;"/>
                        <Label fx:id="profileNameLabel"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #555;"/>
                        <Label fx:id="profileEmailLabel"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #555;"/>
                        <Label fx:id="profilePhoneLabel"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #555;"/>
                        <Label fx:id="profileRoleLabel"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #888;"/>
                    </VBox>
                </VBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>
