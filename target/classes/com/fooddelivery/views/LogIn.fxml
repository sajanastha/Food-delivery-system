<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.fooddelivery.LoginController"
           style="-fx-background-color: linear-gradient(to bottom, #1C3A5E 0%, #24496F 48%, #FFF7ED 48%, #FFF7ED 100%);">

    <VBox alignment="CENTER"
          spacing="0"
          maxWidth="430"
          maxHeight="500">

        <VBox alignment="CENTER"
              spacing="10"
              style="-fx-background-color: #1C3A5E;
                     -fx-padding: 34 40 28 40;
                     -fx-background-radius: 18 18 0 0;">

            <Label text="Food Delivery System"
                   style="-fx-font-size: 21px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>

            <Label text="Sign in to continue"
                   style="-fx-font-size: 12px;
                          -fx-text-fill: #FCD9A8;"/>
        </VBox>

        <VBox spacing="13"
              style="-fx-background-color: white;
                     -fx-padding: 30 36 26 36;
                     -fx-background-radius: 0 0 18 18;
                     -fx-effect: dropshadow(gaussian, rgba(28,58,94,0.12), 14, 0, 0, 4);">

            <Label text="Email Address"
                   style="-fx-font-size: 11px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #334155;"/>
            <TextField fx:id="emailField"
                       promptText="Enter your email"
                       style="-fx-border-color: #FDBA74;
                              -fx-border-radius: 10;
                              -fx-background-radius: 10;
                              -fx-padding: 10 12;
                              -fx-font-size: 12px;"/>

            <Label text="Password"
                   style="-fx-font-size: 11px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #334155;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           style="-fx-border-color: #FDBA74;
                                  -fx-border-radius: 10;
                                  -fx-background-radius: 10;
                                  -fx-padding: 10 12;
                                  -fx-font-size: 12px;"/>

            <Label fx:id="errorLabel"
                   text=""
                   style="-fx-text-fill: #DC2626;
                          -fx-font-size: 11px;"
                   wrapText="true"/>

            <Button text="Sign In"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    prefHeight="42"
                    style="-fx-background-color: #2563EB;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;"/>

            <Separator/>

            <VBox alignment="CENTER" spacing="7">
                <Label text="Don't have an account yet?"
                       style="-fx-text-fill: #64748B;
                              -fx-font-size: 11px;"/>

                <Button text="Register Now"
                        onAction="#handleRegister"
                        maxWidth="Infinity"
                        prefHeight="38"
                        style="-fx-background-color: #FF7A00;
                               -fx-background-radius: 10;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;"/>
            </VBox>

            <Label text="Admin: admin@gmail.com / admin123"
                   style="-fx-text-fill: #94A3B8;
                          -fx-font-size: 9px;"
                   maxWidth="Infinity"
                   alignment="CENTER"/>
        </VBox>
    </VBox>
</StackPane>
