<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fooddelivery.CustomerDashboardController"
            prefWidth="1140" prefHeight="760"
            style="-fx-background-color: #F4F7FB;">

    <top>
        <VBox style="-fx-background-color: white;
                     -fx-border-color: #E2E8F0;
                     -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="18"
                  style="-fx-padding: 14 24;">
                <Label text="QuickBite"
                       style="-fx-font-size: 22px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #F97316;"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="welcomeLabel"
                       style="-fx-text-fill: #475569;
                              -fx-font-size: 13px;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Logout"
                        onAction="#handleLogout"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #64748B;
                               -fx-border-color: #CBD5E1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-padding: 7 18;
                               -fx-cursor: hand;"/>
            </HBox>

            <HBox spacing="4"
                  style="-fx-padding: 0 24 0 24;">
                <Button fx:id="homeTabButton"
                        text="Home"
                        onAction="#showHomeTab"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #F97316;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-padding: 10 18;
                               -fx-cursor: hand;"/>
                <Button fx:id="orderTabButton"
                        text="Order Food"
                        onAction="#showOrderTab"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #64748B;
                               -fx-font-size: 13px;
                               -fx-padding: 10 18;
                               -fx-cursor: hand;"/>
                <Button fx:id="historyTabButton"
                        text="Order History"
                        onAction="#showHistoryTab"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #64748B;
                               -fx-font-size: 13px;
                               -fx-padding: 10 18;
                               -fx-cursor: hand;"/>
                <Button fx:id="profileTabButton"
                        text="My Profile"
                        onAction="#showProfile"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #64748B;
                               -fx-font-size: 13px;
                               -fx-padding: 10 18;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>

            <VBox fx:id="homePanel" spacing="18"
                  style="-fx-padding: 20 22 22 22;">
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Customer Home"
                               style="-fx-font-size: 20px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #0F172A;"/>
                        <Label text="Popular picks and restaurants based on today's orders."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #64748B;"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="4">
                        <Label fx:id="homeDateLabel"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #475569;"/>
                        <Label fx:id="homeStatusLabel"
                               wrapText="true"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748B;"/>
                    </VBox>
                </HBox>

                <HBox spacing="18" VBox.vgrow="ALWAYS">
                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 16, 0, 0, 3);">
                        <Label text="Top 3 Popular Foods"
                               style="-fx-font-size: 16px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1E293B;"/>
                        <Label text="Best-selling foods ordered today."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #64748B;"/>
                        <ListView fx:id="topFoodsListView"
                                  VBox.vgrow="ALWAYS"
                                  style="-fx-border-color: #E2E8F0;
                                         -fx-border-radius: 10;
                                         -fx-background-radius: 10;
                                         -fx-font-size: 13px;"/>
                    </VBox>

                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 16, 0, 0, 3);">
                        <Label text="Top 3 Popular Restaurants"
                               style="-fx-font-size: 16px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1E293B;"/>
                        <Label text="Restaurants receiving the most orders today."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #64748B;"/>
                        <ListView fx:id="topRestaurantsListView"
                                  VBox.vgrow="ALWAYS"
                                  style="-fx-border-color: #E2E8F0;
                                         -fx-border-radius: 10;
                                         -fx-background-radius: 10;
                                         -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="orderPanel" spacing="0" visible="false" managed="false">
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-padding: 14 20 10 20;
                             -fx-background-color: white;
                             -fx-border-color: #EBEBEB;
                             -fx-border-width: 0 0 1 0;">
                    <TextField fx:id="searchField"
                               promptText="Search restaurants or dishes..."
                               prefWidth="340"
                               style="-fx-border-color: #E0E0E0;
                                      -fx-border-radius: 20;
                                      -fx-background-radius: 20;
                                      -fx-padding: 7 16;
                                      -fx-font-size: 13px;
                                      -fx-background-color: #F8FAFC;"/>
                    <Button text="Search"
                            onAction="#handleSearch"
                            style="-fx-background-color: #F97316;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 20;
                                   -fx-padding: 7 20;
                                   -fx-font-size: 13px;
                                   -fx-cursor: hand;"/>
                    <Button text="All"
                            onAction="#handleShowAll"
                            style="-fx-background-color: #F1F5F9;
                                   -fx-text-fill: #555;
                                   -fx-background-radius: 20;
                                   -fx-padding: 7 14;
                                   -fx-font-size: 13px;
                                   -fx-cursor: hand;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label fx:id="browseStatus"
                           style="-fx-text-fill: #64748B;
                                  -fx-font-size: 12px;"/>
                </HBox>

                <HBox VBox.vgrow="ALWAYS">
                    <VBox prefWidth="320"
                          style="-fx-background-color: white;
                                 -fx-border-color: #EBEBEB;
                                 -fx-border-width: 0 1 0 0;">
                        <Label text="Restaurants"
                               style="-fx-padding: 14 18 8 18;
                                      -fx-font-size: 12px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #64748B;"/>
                        <ListView fx:id="restaurantListView"
                                  VBox.vgrow="ALWAYS"
                                  onMouseClicked="#handleRestaurantSelected"
                                  style="-fx-border-color: transparent;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="restaurantInfoLabel"
                               text="Select a restaurant"
                               wrapText="true"
                               style="-fx-text-fill: #94A3B8;
                                      -fx-font-size: 11px;
                                      -fx-padding: 6 14 10 14;"/>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding: 14 18 8 18;
                                     -fx-background-color: white;
                                     -fx-border-color: #EBEBEB;
                                     -fx-border-width: 0 0 1 0;">
                            <Label fx:id="menuTitleLabel"
                                   text="Select a restaurant to view menu"
                                   style="-fx-font-size: 14px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #1E293B;"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Label fx:id="cartCountLabel"
                                   text=""
                                   style="-fx-font-size: 12px;
                                          -fx-text-fill: #F97316;
                                          -fx-font-weight: bold;"/>
                        </HBox>

                        <ListView fx:id="menuListView"
                                  VBox.vgrow="ALWAYS"
                                  style="-fx-border-color: transparent;
                                         -fx-font-size: 13px;
                                         -fx-padding: 0 10;
                                         -fx-background-color: #F4F7FB;"/>

                        <HBox alignment="CENTER_RIGHT" spacing="10"
                              style="-fx-padding: 12 18;
                                     -fx-background-color: white;
                                     -fx-border-color: #EBEBEB;
                                     -fx-border-width: 1 0 0 0;">
                            <Label fx:id="selectedItemLabel"
                                   text=""
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-text-fill: #475569;
                                          -fx-font-size: 12px;"/>
                            <Button text="View Cart"
                                    onAction="#handleViewCart"
                                    style="-fx-background-color: white;
                                           -fx-text-fill: #F97316;
                                           -fx-border-color: #F97316;
                                           -fx-border-radius: 8;
                                           -fx-background-radius: 8;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-padding: 9 20;
                                           -fx-cursor: hand;"/>
                            <Button text="+ Add to Cart"
                                    onAction="#handleAddToCart"
                                    style="-fx-background-color: #F97316;
                                           -fx-text-fill: white;
                                           -fx-background-radius: 8;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-padding: 9 20;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="historyPanel" spacing="0" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 16 22 12 22;
                             -fx-background-color: white;
                             -fx-border-color: #EBEBEB;
                             -fx-border-width: 0 0 1 0;">
                    <VBox spacing="2">
                        <Label text="Order History"
                               style="-fx-font-size: 16px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1E293B;"/>
                        <Label text="See restaurant names, food items, and feedback."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #64748B;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label fx:id="historyStatusLabel"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #64748B;"/>
                    <Button text="Refresh"
                            onAction="#handleRefreshHistory"
                            style="-fx-background-color: #F1F5F9;
                                   -fx-text-fill: #475569;
                                   -fx-background-radius: 8;
                                   -fx-padding: 7 16;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;"/>
                </HBox>

                <SplitPane dividerPositions="0.42" VBox.vgrow="ALWAYS"
                           style="-fx-padding: 16 18 18 18;">
                    <items>
                        <VBox spacing="10"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 12;
                                     -fx-padding: 16;">
                            <Label text="Orders"
                                   style="-fx-font-size: 14px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #1E293B;"/>
                            <ListView fx:id="historyListView"
                                      VBox.vgrow="ALWAYS"
                                      onMouseClicked="#handleHistorySelected"
                                      style="-fx-border-color: #E2E8F0;
                                             -fx-border-radius: 10;
                                             -fx-background-radius: 10;
                                             -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="10"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 12;
                                     -fx-padding: 16;">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Order Details"
                                       style="-fx-font-size: 14px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #1E293B;"/>
                                <Pane HBox.hgrow="ALWAYS"/>
                                <Button fx:id="feedbackButton"
                                        text="Add Feedback"
                                        onAction="#handleFeedbackAction"
                                        disable="true"
                                        style="-fx-background-color: #2563EB;
                                               -fx-text-fill: white;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 8;
                                               -fx-padding: 8 16;
                                               -fx-cursor: hand;"/>
                            </HBox>
                            <TextArea fx:id="historyDetailArea"
                                      VBox.vgrow="ALWAYS"
                                      editable="false"
                                      wrapText="true"
                                      style="-fx-font-family: Consolas;
                                             -fx-font-size: 12px;
                                             -fx-border-color: #E2E8F0;
                                             -fx-border-radius: 10;
                                             -fx-background-radius: 10;"/>
                        </VBox>
                    </items>
                </SplitPane>
            </VBox>

            <VBox fx:id="profilePanel" spacing="0" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT"
                      style="-fx-padding: 16 22 12 22;
                             -fx-background-color: white;
                             -fx-border-color: #EBEBEB;
                             -fx-border-width: 0 0 1 0;">
                    <VBox spacing="2">
                        <Label text="My Profile"
                               style="-fx-font-size: 16px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1E293B;"/>
                        <Label text="Your customer account details"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #64748B;"/>
                    </VBox>
                </HBox>

                <VBox spacing="0"
                      style="-fx-padding: 24;
                             -fx-background-color: #F4F7FB;">
                    <VBox spacing="16"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 28;
                                 -fx-border-color: #E2E8F0;
                                 -fx-border-radius: 14;
                                 -fx-max-width: 520;">
                        <Label text="Account Information"
                               style="-fx-font-size: 15px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1E293B;"/>
                        <Label fx:id="profileNameLabel"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #475569;"/>
                        <Label fx:id="profileEmailLabel"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #475569;"/>
                        <Label fx:id="profilePhoneLabel"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #475569;"/>
                        <Label fx:id="profileRoleLabel"
                               style="-fx-font-size: 13px;
                                      -fx-text-fill: #64748B;"/>
                    </VBox>
                </VBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>
