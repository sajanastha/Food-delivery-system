<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fooddelivery.CustomerDashboardController"
            prefWidth="980" prefHeight="700"
            style="-fx-background-color: #F7F7F7;">

    <!-- TOP NAV -->
    <top>
        <VBox style="-fx-background-color: white;
                     -fx-border-color: #E8E8E8;
                     -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-padding: 14 24;">
                <Label text="🍴 QuickBite"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #FF6B35;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="welcomeLabel"
                       style="-fx-text-fill: #555;
                              -fx-font-size: 13px;"/>
                <Button text="Logout"
                        onAction="#handleLogout"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #888;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;
                               -fx-border-color: #ddd;
                               -fx-border-radius: 6;
                               -fx-background-radius: 6;
                               -fx-padding: 5 14;"/>
            </HBox>

            <!-- Tab Navigation -->
            <HBox spacing="0"
                  style="-fx-padding: 0 24 0 24;">
                <Button fx:id="btnBrowse" text="Browse"
                        onAction="#showBrowse"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #FF6B35;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-padding: 10 20;
                               -fx-cursor: hand;
                               -fx-border-color: transparent transparent #FF6B35 transparent;
                               -fx-border-width: 0 0 2 0;"/>
                <Button fx:id="btnCart" text="My Cart"
                        onAction="#showCart"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #888;
                               -fx-font-size: 13px;
                               -fx-padding: 10 20;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnHistory" text="Orders"
                        onAction="#showHistory"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #888;
                               -fx-font-size: 13px;
                               -fx-padding: 10 20;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT AREA (switched by nav buttons) -->
    <center>
        <StackPane fx:id="contentArea">

            <!-- ===== BROWSE PANEL ===== -->
            <VBox fx:id="browsePanel" spacing="0">
                <!-- Search bar -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-padding: 16 24 12 24;
                             -fx-background-color: white;
                             -fx-border-color: #E8E8E8;
                             -fx-border-width: 0 0 1 0;">
                    <TextField fx:id="searchField"
                               promptText="Search restaurants..."
                               prefWidth="300"
                               style="-fx-border-color: #E0E0E0;
                                      -fx-border-radius: 20;
                                      -fx-background-radius: 20;
                                      -fx-padding: 8 16;
                                      -fx-font-size: 13px;
                                      -fx-background-color: #F7F7F7;"/>
                    <Button text="Search"
                            onAction="#handleSearch"
                            style="-fx-background-color: #FF6B35;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 20;
                                   -fx-font-size: 13px;
                                   -fx-cursor: hand;"/>
                    <Button text="All"
                            onAction="#handleShowAll"
                            style="-fx-background-color: #F0F0F0;
                                   -fx-text-fill: #555;
                                   -fx-background-radius: 20;
                                   -fx-padding: 8 16;
                                   -fx-font-size: 13px;
                                   -fx-cursor: hand;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label fx:id="browseStatus"
                           style="-fx-text-fill: #999;
                                  -fx-font-size: 12px;"/>
                </HBox>

                <!-- Two-column layout: restaurants left, menu right -->
                <HBox spacing="0" VBox.vgrow="ALWAYS">

                    <!-- Restaurant list (left panel) -->
                    <VBox prefWidth="320"
                          style="-fx-background-color: white;
                                 -fx-border-color: #E8E8E8;
                                 -fx-border-width: 0 1 0 0;">
                        <Label text="Restaurants"
                               style="-fx-padding: 14 20 10 20;
                                      -fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #333;"/>
                        <ListView fx:id="restaurantListView"
                                  VBox.vgrow="ALWAYS"
                                  onMouseClicked="#handleRestaurantSelected"
                                  style="-fx-border-color: transparent;
                                         -fx-background-color: transparent;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="restaurantInfoLabel"
                               text="Select a restaurant to view its menu"
                               wrapText="true"
                               style="-fx-text-fill: #999;
                                      -fx-font-size: 11px;
                                      -fx-padding: 8 16;"/>
                    </VBox>

                    <!-- Menu items (right panel) -->
                    <VBox HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #F7F7F7;">
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding: 14 20 10 20;">
                            <Label text="Menu Items"
                                   style="-fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #333;"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Button text="+ Add to Cart"
                                    onAction="#handleAddToCart"
                                    style="-fx-background-color: #FF6B35;
                                           -fx-text-fill: white;
                                           -fx-background-radius: 20;
                                           -fx-padding: 7 18;
                                           -fx-font-size: 12px;
                                           -fx-font-weight: bold;
                                           -fx-cursor: hand;"/>
                        </HBox>
                        <ListView fx:id="menuListView"
                                  VBox.vgrow="ALWAYS"
                                  style="-fx-border-color: transparent;
                                         -fx-background-color: transparent;
                                         -fx-font-size: 13px;
                                         -fx-padding: 0 12;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ===== CART PANEL ===== -->
            <VBox fx:id="cartPanel" spacing="0" visible="false">
                <Label text="Your Cart"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #333;
                              -fx-padding: 18 24 10 24;
                              -fx-background-color: white;
                              -fx-border-color: #E8E8E8;
                              -fx-border-width: 0 0 1 0;"/>

                <HBox spacing="16" VBox.vgrow="ALWAYS"
                      style="-fx-padding: 16 24;">

                    <!-- Cart items left -->
                    <VBox spacing="10" prefWidth="420">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Items"
                                   style="-fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #444;"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Button text="Remove Selected"
                                    onAction="#handleRemoveFromCart"
                                    style="-fx-background-color: #FFF0ED;
                                           -fx-text-fill: #FF6B35;
                                           -fx-border-color: #FFD5C8;
                                           -fx-border-radius: 6;
                                           -fx-background-radius: 6;
                                           -fx-font-size: 12px;
                                           -fx-cursor: hand;
                                           -fx-padding: 5 12;"/>
                        </HBox>
                        <ListView fx:id="cartListView"
                                  prefHeight="280"
                                  style="-fx-border-color: #E8E8E8;
                                         -fx-border-radius: 8;
                                         -fx-background-color: white;
                                         -fx-font-size: 13px;"/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Delivery address:"
                                   style="-fx-font-size: 13px;
                                          -fx-text-fill: #555;"/>
                            <TextField fx:id="addressField"
                                       promptText="Enter delivery address"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-border-color: #E0E0E0;
                                              -fx-border-radius: 8;
                                              -fx-background-radius: 8;
                                              -fx-padding: 8 12;
                                              -fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>

                    <!-- Order summary right -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="Order Summary"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #444;"/>
                        <TextArea fx:id="pricingArea"
                                  prefHeight="200"
                                  editable="false"
                                  style="-fx-font-family: monospace;
                                         -fx-font-size: 12px;
                                         -fx-border-color: #E8E8E8;
                                         -fx-border-radius: 8;
                                         -fx-background-color: white;"/>
                        <Button text="Place Order"
                                onAction="#handlePlaceOrder"
                                maxWidth="Infinity"
                                prefHeight="44"
                                style="-fx-background-color: #FF6B35;
                                       -fx-text-fill: white;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;"/>
                        <Label fx:id="cartStatus" text=""
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #666;"
                               wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ===== HISTORY PANEL ===== -->
            <VBox fx:id="historyPanel" spacing="0" visible="false">
                <HBox alignment="CENTER_LEFT"
                      style="-fx-padding: 16 24 12 24;
                             -fx-background-color: white;
                             -fx-border-color: #E8E8E8;
                             -fx-border-width: 0 0 1 0;">
                    <Label text="Order History"
                           style="-fx-font-size: 16px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #333;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh"
                            onAction="#handleRefreshHistory"
                            style="-fx-background-color: #F0F0F0;
                                   -fx-text-fill: #555;
                                   -fx-background-radius: 8;
                                   -fx-padding: 7 16;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;"/>
                </HBox>
                <ListView fx:id="historyListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-border-color: transparent;
                                 -fx-font-size: 13px;
                                 -fx-padding: 12 20;"/>
            </VBox>

        </StackPane>
    </center>
</BorderPane>
