<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fooddelivery.RestaurantDashboardController"
            prefWidth="1140" prefHeight="760"
            style="-fx-background-color: #F5F5DC;">

    <!-- ── TOP HEADER ───────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #4d9078;
                     -fx-padding: 14 24;">
            <Label text="🍽 Restaurant Portal"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
            <Separator orientation="VERTICAL"
                       style="-fx-background-color: rgba(255,255,255,0.4);"/>
            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: rgba(255,255,255,0.88);
                          -fx-font-size: 13px;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="menuStatus"
                   text=""
                   style="-fx-text-fill: rgba(255,255,255,0.8);
                          -fx-font-size: 12px;"/>
            <Button text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color: rgba(255,255,255,0.18);
                           -fx-text-fill: white;
                           -fx-border-color: rgba(255,255,255,0.5);
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-font-size: 12px;
                           -fx-padding: 6 16;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ── CONTENT ───────────────────────────────────────────────────── -->
    <center>
        <StackPane fx:id="contentStack"
                   style="-fx-background-color: #F5F5DC;">

            <!-- MENU PANEL -->
            <VBox fx:id="menuPanel" spacing="14"
                  style="-fx-padding: 18;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="3">
                        <Label text="Menu Management"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <Label text="Add, edit or remove items from your menu."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #7a7a5a;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="+ Add New Item"
                            onAction="#showAddItemDialog"
                            style="-fx-background-color: #FF7518;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 9 20;
                                   -fx-cursor: hand;"/>
                </HBox>

                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <!-- Items list -->
                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Current Items"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <ListView fx:id="menuListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="340"
                                  onMouseClicked="#handleMenuSelected"
                                  style="-fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <HBox spacing="8">
                            <Button text="Toggle Available"
                                    onAction="#handleToggle"
                                    style="-fx-background-color: #eef7f3;
                                           -fx-text-fill: #4d9078;
                                           -fx-border-color: #4d9078;
                                           -fx-border-radius: 7;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 12px;
                                           -fx-padding: 7 14;
                                           -fx-cursor: hand;"/>
                            <Button text="Delete"
                                    onAction="#handleDeleteItem"
                                    style="-fx-background-color: #fff0e0;
                                           -fx-text-fill: #c0390a;
                                           -fx-border-color: #FF7518;
                                           -fx-border-radius: 7;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 12px;
                                           -fx-padding: 7 14;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- Edit form -->
                    <VBox spacing="10" prefWidth="300"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Edit Selected Item"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <Label text="Item Name"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #7a7a5a;"/>
                        <TextField fx:id="itemNameField"
                                   promptText="e.g. Chicken Momo"
                                   style="-fx-border-color: #d8d8b8;
                                          -fx-border-radius: 7;
                                          -fx-background-radius: 7;
                                          -fx-padding: 8 12;
                                          -fx-font-size: 13px;"/>
                        <Label text="Price (NPR)"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #7a7a5a;"/>
                        <TextField fx:id="itemPriceField"
                                   promptText="e.g. 250"
                                   style="-fx-border-color: #d8d8b8;
                                          -fx-border-radius: 7;
                                          -fx-background-radius: 7;
                                          -fx-padding: 8 12;
                                          -fx-font-size: 13px;"/>
                        <Label text="Category"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #7a7a5a;"/>
                        <TextField fx:id="itemCategoryField"
                                   promptText="Main, Starter, Drink..."
                                   style="-fx-border-color: #d8d8b8;
                                          -fx-border-radius: 7;
                                          -fx-background-radius: 7;
                                          -fx-padding: 8 12;
                                          -fx-font-size: 13px;"/>
                        <Label text="Description (optional)"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #7a7a5a;"/>
                        <TextArea fx:id="itemDescField"
                                  prefHeight="70"
                                  promptText="Short description..."
                                  style="-fx-border-color: #d8d8b8;
                                         -fx-border-radius: 7;
                                         -fx-background-radius: 7;
                                         -fx-font-size: 13px;"/>
                        <Button text="Update Item"
                                onAction="#handleUpdateItem"
                                maxWidth="Infinity"
                                prefHeight="38"
                                style="-fx-background-color: #4d9078;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 8;
                                       -fx-font-size: 13px;
                                       -fx-font-weight: bold;
                                       -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ORDERS PANEL -->
            <VBox fx:id="ordersPanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="3">
                        <Label text="Incoming Orders"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <Label text="Confirm or cancel customer orders."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #7a7a5a;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh"
                            onAction="#handleRefreshOrders"
                            style="-fx-background-color: #e8e8c8;
                                   -fx-text-fill: #555;
                                   -fx-background-radius: 8;
                                   -fx-padding: 8 18;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;"/>
                </HBox>

                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" prefWidth="380"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Orders"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <ListView fx:id="orderListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="300"
                                  onMouseClicked="#handleOrderSelected"
                                  style="-fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <HBox spacing="8">
                            <Button text="✔ Confirm"
                                    onAction="#handleConfirm"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #4d9078;
                                           -fx-text-fill: white;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-padding: 9 0;
                                           -fx-cursor: hand;"/>
                            <Button text="✗ Cancel"
                                    onAction="#handleCancel"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #fff0e0;
                                           -fx-text-fill: #c0390a;
                                           -fx-border-color: #FF7518;
                                           -fx-border-radius: 7;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-padding: 9 0;
                                           -fx-cursor: hand;"/>
                        </HBox>
                        <Label fx:id="orderStatus"
                               text=""
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #7a7a5a;"/>
                    </VBox>

                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Order Details"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <TextArea fx:id="orderDetailArea"
                                  VBox.vgrow="ALWAYS"
                                  editable="false"
                                  promptText="Click an order to see details..."
                                  style="-fx-font-family: Consolas;
                                         -fx-font-size: 12px;
                                         -fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- REPORTS PANEL -->
            <VBox fx:id="reportsPanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <VBox spacing="3">
                    <Label text="Sales Reports"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #2D2D2D;"/>
                    <Label text="View revenue, orders and popular items."
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #7a7a5a;"/>
                </VBox>

                <HBox spacing="10">
                    <Button text="📅  Weekly Report  (last 7 days)"
                            onAction="#handleWeekly"
                            style="-fx-background-color: #FF7518;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 10 22;
                                   -fx-cursor: hand;"/>
                    <Button text="📅  Monthly Report  (last 30 days)"
                            onAction="#handleMonthly"
                            style="-fx-background-color: #4d9078;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 10 22;
                                   -fx-cursor: hand;"/>
                </HBox>

                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-padding: 20;
                             -fx-border-color: #d8d8b8;
                             -fx-border-radius: 12;
                             -fx-border-width: 1;">
                    <TextArea fx:id="reportArea"
                              VBox.vgrow="ALWAYS"
                              editable="false"
                              promptText="Click a report button above to generate..."
                              style="-fx-font-family: Consolas;
                                     -fx-font-size: 13px;
                                     -fx-border-color: transparent;"/>
                </VBox>
            </VBox>

            <!-- FEEDBACK PANEL -->
            <VBox fx:id="feedbackPanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="3">
                        <Label text="Customer Feedback"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <Label text="See what customers say about your food."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #7a7a5a;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Load Feedback"
                            onAction="#handleLoadFeedback"
                            style="-fx-background-color: #FF7518;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-padding: 9 20;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;"/>
                </HBox>

                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-padding: 16;
                             -fx-border-color: #d8d8b8;
                             -fx-border-radius: 12;
                             -fx-border-width: 1;">
                    <ListView fx:id="feedbackListView"
                              VBox.vgrow="ALWAYS"
                              style="-fx-border-color: transparent;
                                     -fx-font-size: 13px;"/>
                </VBox>
            </VBox>

        </StackPane>
    </center>

    <!-- ── BOTTOM NAV BAR ─────────────────────────────────────────────── -->
    <bottom>
        <HBox style="-fx-background-color: white;
                     -fx-border-color: #d8d8b8;
                     -fx-border-width: 1 0 0 0;">
            <Button fx:id="menuTabButton"
                    text="🍽  Menu"
                    onAction="#goMenu"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #4d9078;
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button fx:id="ordersTabButton"
                    text="📦  Orders"
                    onAction="#goOrders"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button fx:id="reportsTabButton"
                    text="📊  Reports"
                    onAction="#goReports"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button fx:id="feedbackTabButton"
                    text="💬  Feedback"
                    onAction="#goFeedback"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
        </HBox>
    </bottom>

</BorderPane>