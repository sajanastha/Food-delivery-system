<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fooddelivery.RestaurantDashboardController"
            prefWidth="1020" prefHeight="720"
            style="-fx-background-color: #F4F6F8;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1A1A2E;
                     -fx-padding: 14 28;">
            <Label text="Restaurant Portal"
                   style="-fx-font-size: 16px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
            <Separator orientation="VERTICAL"
                       style="-fx-background-color: #444;"/>
            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: #AAB4C8;
                          -fx-font-size: 13px;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #AAB4C8;
                           -fx-border-color: #444;
                           -fx-border-radius: 6;
                           -fx-background-radius: 6;
                           -fx-font-size: 12px;
                           -fx-cursor: hand;
                           -fx-padding: 6 16;"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR NAVIGATION -->
    <left>
        <VBox spacing="4"
              style="-fx-background-color: white;
                     -fx-padding: 20 12;
                     -fx-border-color: #E5E8EC;
                     -fx-border-width: 0 1 0 0;
                     -fx-min-width: 180px;">

            <Label text="MENU"
                   style="-fx-font-size: 10px;
                          -fx-text-fill: #AAB;
                          -fx-padding: 0 8 8 8;
                          -fx-font-weight: bold;"/>

            <Button text="  Menu Items"
                    onAction="#goMenu"
                    maxWidth="Infinity"
                    style="-fx-background-color: #EEF2FF;
                           -fx-text-fill: #4F46E5;
                           -fx-alignment: CENTER-LEFT;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 10 16;
                           -fx-cursor: hand;"/>

            <Button text="  Orders"
                    onAction="#goOrders"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555;
                           -fx-alignment: CENTER-LEFT;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-padding: 10 16;
                           -fx-cursor: hand;"/>

            <Button text="  Reports"
                    onAction="#goReports"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555;
                           -fx-alignment: CENTER-LEFT;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-padding: 10 16;
                           -fx-cursor: hand;"/>

            <Button text="  Feedback"
                    onAction="#goFeedback"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555;
                           -fx-alignment: CENTER-LEFT;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-padding: 10 16;
                           -fx-cursor: hand;"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <Label fx:id="menuStatus" text=""
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #666;
                          -fx-padding: 4 8;"
                   wrapText="true"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <StackPane fx:id="contentStack"
                   style="-fx-padding: 20;">

            <!-- ===== MENU PANEL ===== -->
            <VBox fx:id="menuPanel" spacing="14">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="2">
                        <Label text="Menu Management"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1A1A2E;"/>
                        <Label text="Add, edit or remove items from your menu"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #888;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="+ Add New Item"
                            onAction="#showAddItemDialog"
                            style="-fx-background-color: #4F46E5;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 9 20;
                                   -fx-cursor: hand;"/>
                </HBox>

                <!-- Menu list + actions -->
                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <!-- Items list -->
                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 10;
                                 -fx-padding: 16;
                                 -fx-border-color: #E5E8EC;
                                 -fx-border-radius: 10;">
                        <Label text="Current Items"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #333;"/>
                        <ListView fx:id="menuListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="340"
                                  onMouseClicked="#handleMenuSelected"
                                  style="-fx-border-color: #F0F0F0;
                                         -fx-border-radius: 6;
                                         -fx-font-size: 13px;"/>
                        <HBox spacing="8">
                            <Button text="Toggle Available"
                                    onAction="#handleToggle"
                                    style="-fx-background-color: #EEF2FF;
                                           -fx-text-fill: #4F46E5;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 12px;
                                           -fx-padding: 7 14;
                                           -fx-cursor: hand;"/>
                            <Button text="Delete"
                                    onAction="#handleDeleteItem"
                                    style="-fx-background-color: #FFF1F1;
                                           -fx-text-fill: #DC2626;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 12px;
                                           -fx-padding: 7 14;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- Edit form -->
                    <VBox spacing="10" prefWidth="300"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 10;
                                 -fx-padding: 16;
                                 -fx-border-color: #E5E8EC;
                                 -fx-border-radius: 10;">
                        <Label text="Edit Selected Item"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #333;"/>

                        <Label text="Item Name"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #888;"/>
                        <TextField fx:id="itemNameField"
                                   promptText="e.g. Chicken Momo"
                                   style="-fx-border-color: #E0E0E0;
                                          -fx-border-radius: 7;
                                          -fx-background-radius: 7;
                                          -fx-padding: 8 12;
                                          -fx-font-size: 13px;"/>

                        <Label text="Price (NPR)"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #888;"/>
                        <TextField fx:id="itemPriceField"
                                   promptText="e.g. 250"
                                   style="-fx-border-color: #E0E0E0;
                                          -fx-border-radius: 7;
                                          -fx-background-radius: 7;
                                          -fx-padding: 8 12;
                                          -fx-font-size: 13px;"/>

                        <Label text="Category"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #888;"/>
                        <TextField fx:id="itemCategoryField"
                                   promptText="e.g. Main, Starter, Drink"
                                   style="-fx-border-color: #E0E0E0;
                                          -fx-border-radius: 7;
                                          -fx-background-radius: 7;
                                          -fx-padding: 8 12;
                                          -fx-font-size: 13px;"/>

                        <Label text="Description (optional)"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #888;"/>
                        <TextArea fx:id="itemDescField"
                                  prefHeight="70"
                                  promptText="Short description..."
                                  style="-fx-border-color: #E0E0E0;
                                         -fx-border-radius: 7;
                                         -fx-background-radius: 7;
                                         -fx-font-size: 13px;"/>

                        <Button text="Update Item"
                                onAction="#handleUpdateItem"
                                maxWidth="Infinity"
                                prefHeight="38"
                                style="-fx-background-color: #4F46E5;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 8;
                                       -fx-font-size: 13px;
                                       -fx-font-weight: bold;
                                       -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ===== ORDERS PANEL ===== -->
            <VBox fx:id="ordersPanel" spacing="14" visible="false">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2">
                        <Label text="Incoming Orders"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1A1A2E;"/>
                        <Label text="Confirm or cancel customer orders"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #888;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh"
                            onAction="#handleRefreshOrders"
                            style="-fx-background-color: #F0F0F0;
                                   -fx-text-fill: #555;
                                   -fx-background-radius: 8;
                                   -fx-padding: 8 18;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;"/>
                </HBox>

                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" prefWidth="380"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 10;
                                 -fx-padding: 16;
                                 -fx-border-color: #E5E8EC;
                                 -fx-border-radius: 10;">
                        <Label text="Orders"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #333;"/>
                        <ListView fx:id="orderListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="300"
                                  onMouseClicked="#handleOrderSelected"
                                  style="-fx-border-color: #F0F0F0;
                                         -fx-border-radius: 6;
                                         -fx-font-size: 13px;"/>
                        <HBox spacing="8">
                            <Button text="Confirm"
                                    onAction="#handleConfirm"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #ECFDF5;
                                           -fx-text-fill: #059669;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-padding: 9 0;
                                           -fx-cursor: hand;"/>
                            <Button text="Cancel"
                                    onAction="#handleCancel"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #FFF1F1;
                                           -fx-text-fill: #DC2626;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-padding: 9 0;
                                           -fx-cursor: hand;"/>
                        </HBox>
                        <Label fx:id="orderStatus" text=""
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #666;"/>
                    </VBox>

                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 10;
                                 -fx-padding: 16;
                                 -fx-border-color: #E5E8EC;
                                 -fx-border-radius: 10;">
                        <Label text="Order Details"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #333;"/>
                        <TextArea fx:id="orderDetailArea"
                                  VBox.vgrow="ALWAYS"
                                  editable="false"
                                  promptText="Click an order to see details..."
                                  style="-fx-font-family: monospace;
                                         -fx-font-size: 12px;
                                         -fx-border-color: #F0F0F0;
                                         -fx-border-radius: 6;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ===== REPORTS PANEL ===== -->
            <VBox fx:id="reportsPanel" spacing="14" visible="false">
                <VBox spacing="2">
                    <Label text="Sales Reports"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #1A1A2E;"/>
                    <Label text="View your revenue, orders and popular items"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #888;"/>
                </VBox>

                <HBox spacing="10">
                    <Button text="Weekly Report  (last 7 days)"
                            onAction="#handleWeekly"
                            style="-fx-background-color: #4F46E5;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 10 22;
                                   -fx-cursor: hand;"/>
                    <Button text="Monthly Report  (last 30 days)"
                            onAction="#handleMonthly"
                            style="-fx-background-color: #0F172A;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 10 22;
                                   -fx-cursor: hand;"/>
                </HBox>

                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 10;
                             -fx-padding: 20;
                             -fx-border-color: #E5E8EC;
                             -fx-border-radius: 10;">
                    <TextArea fx:id="reportArea"
                              VBox.vgrow="ALWAYS"
                              editable="false"
                              promptText="Click a report button above to generate..."
                              style="-fx-font-family: monospace;
                                     -fx-font-size: 13px;
                                     -fx-border-color: transparent;"/>
                </VBox>
            </VBox>

            <!-- ===== FEEDBACK PANEL ===== -->
            <VBox fx:id="feedbackPanel" spacing="14" visible="false">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2">
                        <Label text="Customer Feedback"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1A1A2E;"/>
                        <Label text="See what customers are saying about your food"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #888;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Load Feedback"
                            onAction="#handleLoadFeedback"
                            style="-fx-background-color: #4F46E5;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-padding: 9 20;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;"/>
                </HBox>

                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 10;
                             -fx-padding: 16;
                             -fx-border-color: #E5E8EC;
                             -fx-border-radius: 10;">
                    <ListView fx:id="feedbackListView"
                              VBox.vgrow="ALWAYS"
                              style="-fx-border-color: transparent;
                                     -fx-font-size: 13px;"/>
                </VBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>