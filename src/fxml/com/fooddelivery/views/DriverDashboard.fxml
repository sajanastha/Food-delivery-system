<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fooddelivery.DriverDashboardController"
            prefWidth="1120" prefHeight="760"
            style="-fx-background-color: #F5F5DC;">

    <!-- ── TOP HEADER ───────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #FF7518;
                     -fx-padding: 14 24;">
            <Label text="🚗 Driver Portal"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
            <Separator orientation="VERTICAL"
                       style="-fx-background-color: rgba(255,255,255,0.4);"/>
            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: rgba(255,255,255,0.88);
                          -fx-font-size: 13px;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="availabilityLabel"
                   style="-fx-text-fill: white;
                          -fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-background-color: rgba(0,0,0,0.18);
                          -fx-background-radius: 20;
                          -fx-padding: 4 12;"/>
            <CheckBox fx:id="availabilityToggle"
                      text="Available"
                      onAction="#handleAvailabilityChanged"
                      style="-fx-text-fill: white;
                             -fx-font-size: 12px;"/>
            <Button text="Refresh"
                    onAction="#handleRefresh"
                    style="-fx-background-color: rgba(255,255,255,0.18);
                           -fx-text-fill: white;
                           -fx-background-radius: 8;
                           -fx-padding: 6 14;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ── CONTENT ───────────────────────────────────────────────────── -->
    <center>
        <StackPane>

            <!-- REQUESTS PANEL -->
            <VBox fx:id="requestsPanel" spacing="14"
                  style="-fx-padding: 18;">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="3">
                        <Label text="Delivery Requests"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <Label text="Available orders waiting to be picked up."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #7a7a5a;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label fx:id="summaryLabel"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #7a7a5a;"/>
                </HBox>

                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" prefWidth="380"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Available Requests"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <ListView fx:id="requestListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="260"
                                  onMouseClicked="#handleRequestSelected"
                                  style="-fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <HBox spacing="8">
                            <Button text="✔ Accept"
                                    onAction="#handleAcceptRequest"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #4d9078;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 8;
                                           -fx-padding: 10 14;
                                           -fx-cursor: hand;"/>
                            <Button text="Skip"
                                    onAction="#handleRejectRequest"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #fff0e0;
                                           -fx-text-fill: #c0390a;
                                           -fx-border-color: #FF7518;
                                           -fx-border-radius: 8;
                                           -fx-background-radius: 8;
                                           -fx-font-weight: bold;
                                           -fx-padding: 10 14;
                                           -fx-cursor: hand;"/>
                        </HBox>
                        <Label fx:id="requestStatus"
                               text=""
                               wrapText="true"
                               style="-fx-text-fill: #7a7a5a;
                                      -fx-font-size: 12px;"/>
                    </VBox>

                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Request Details"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <TextArea fx:id="requestDetailArea"
                                  VBox.vgrow="ALWAYS"
                                  editable="false"
                                  wrapText="true"
                                  promptText="Select a request to see details..."
                                  style="-fx-font-family: Consolas;
                                         -fx-font-size: 12px;
                                         -fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ACTIVE PANEL -->
            <VBox fx:id="activePanel" spacing="0"
                  visible="false" managed="false">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 14 22 12 22;
                             -fx-background-color: white;
                             -fx-border-color: #d8d8b8;
                             -fx-border-width: 0 0 1 0;">
                    <Label text="🚚"
                           style="-fx-font-size: 22px;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Current Delivery"
                               style="-fx-font-size: 17px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <Label text="Your active delivery in progress."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #7a7a5a;"/>
                    </VBox>
                    <Label fx:id="activeStatus"
                           text=""
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #4d9078;
                                  -fx-font-weight: bold;"/>
                </HBox>

                <!-- Body -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: #F5F5DC;
                                   -fx-border-color: transparent;">
                    <VBox spacing="16"
                          style="-fx-padding: 24 28;">

                        <!-- No delivery placeholder -->
                        <VBox fx:id="noActiveBox" alignment="CENTER" spacing="12"
                              style="-fx-padding: 60 0;">
                            <Label text="🛵"
                                   style="-fx-font-size: 52px;"/>
                            <Label text="No Active Delivery"
                                   style="-fx-font-size: 18px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <Label text="Accept a request from the Requests tab to start delivering."
                                   style="-fx-font-size: 13px;
                                          -fx-text-fill: #999;"/>
                        </VBox>

                        <!-- Active delivery card -->
                        <VBox fx:id="activeDeliveryCard" spacing="0"
                              visible="false" managed="false"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 16;
                                     -fx-border-color: #FF7518;
                                     -fx-border-radius: 16;
                                     -fx-border-width: 2;
                                     -fx-effect: dropshadow(gaussian, rgba(255,117,24,0.18), 12, 0, 0, 4);">

                            <!-- Card top — order badge -->
                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-padding: 16 20 14 20;
                                         -fx-background-color: #FF7518;
                                         -fx-background-radius: 14 14 0 0;">
                                <Label fx:id="activeOrderBadge"
                                       text="Order #—"
                                       style="-fx-font-size: 17px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: white;"/>
                                <Pane HBox.hgrow="ALWAYS"/>
                                <Label text="IN DELIVERY"
                                       style="-fx-font-size: 11px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: white;
                                              -fx-background-color: rgba(0,0,0,0.22);
                                              -fx-background-radius: 20;
                                              -fx-padding: 3 10;"/>
                            </HBox>

                            <!-- Info rows -->
                            <VBox spacing="12"
                                  style="-fx-padding: 20 22;">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="📍"
                                           style="-fx-font-size: 16px;"/>
                                    <VBox spacing="2">
                                        <Label text="Deliver To"
                                               style="-fx-font-size: 11px;
                                                      -fx-text-fill: #999;"/>
                                        <Label fx:id="activeAddressLabel"
                                               text="—"
                                               wrapText="true"
                                               style="-fx-font-size: 14px;
                                                      -fx-font-weight: bold;
                                                      -fx-text-fill: #1a1a1a;"/>
                                    </VBox>
                                </HBox>
                                <Separator style="-fx-background-color: #f0f0f0;"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="🏪"
                                           style="-fx-font-size: 16px;"/>
                                    <VBox spacing="2">
                                        <Label text="Restaurant"
                                               style="-fx-font-size: 11px;
                                                      -fx-text-fill: #999;"/>
                                        <Label fx:id="activeRestaurantLabel"
                                               text="—"
                                               style="-fx-font-size: 14px;
                                                      -fx-font-weight: bold;
                                                      -fx-text-fill: #1a1a1a;"/>
                                    </VBox>
                                </HBox>
                                <Separator style="-fx-background-color: #f0f0f0;"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="🧾"
                                           style="-fx-font-size: 16px;"/>
                                    <VBox spacing="2">
                                        <Label text="Items"
                                               style="-fx-font-size: 11px;
                                                      -fx-text-fill: #999;"/>
                                        <Label fx:id="activeItemsLabel"
                                               text="—"
                                               wrapText="true"
                                               style="-fx-font-size: 13px;
                                                      -fx-text-fill: #333;"/>
                                    </VBox>
                                </HBox>
                                <Separator style="-fx-background-color: #f0f0f0;"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="💰"
                                           style="-fx-font-size: 16px;"/>
                                    <VBox spacing="2">
                                        <Label text="Total"
                                               style="-fx-font-size: 11px;
                                                      -fx-text-fill: #999;"/>
                                        <Label fx:id="activeTotalLabel"
                                               text="—"
                                               style="-fx-font-size: 16px;
                                                      -fx-font-weight: bold;
                                                      -fx-text-fill: #FF7518;"/>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <!-- Action buttons -->
                            <HBox spacing="12"
                                  style="-fx-padding: 0 20 20 20;">
                                <Button text="✔  Mark as Delivered"
                                        onAction="#handleMarkDelivered"
                                        HBox.hgrow="ALWAYS"
                                        maxWidth="Infinity"
                                        prefHeight="48"
                                        style="-fx-background-color: #4d9078;
                                               -fx-text-fill: white;
                                               -fx-font-size: 14px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 10;
                                               -fx-cursor: hand;"/>
                                <Button text="✕  Cancel"
                                        onAction="#handleCancelDelivery"
                                        prefHeight="48"
                                        prefWidth="120"
                                        style="-fx-background-color: #fff0e0;
                                               -fx-text-fill: #c0390a;
                                               -fx-border-color: #FF7518;
                                               -fx-border-radius: 10;
                                               -fx-background-radius: 10;
                                               -fx-font-weight: bold;
                                               -fx-font-size: 13px;
                                               -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- HISTORY PANEL -->
            <VBox fx:id="driverHistoryPanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <VBox spacing="3">
                    <Label text="Delivery History"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #2D2D2D;"/>
                    <Label text="All your completed and cancelled deliveries."
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #7a7a5a;"/>
                </VBox>

                <SplitPane dividerPositions="0.45"
                           VBox.vgrow="ALWAYS">
                    <items>
                        <VBox spacing="10"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 12;
                                     -fx-padding: 14;
                                     -fx-border-color: #d8d8b8;
                                     -fx-border-radius: 12;
                                     -fx-border-width: 1;">
                            <Label text="Past Deliveries"
                                   style="-fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #2D2D2D;"/>
                            <ListView fx:id="historyListView"
                                      VBox.vgrow="ALWAYS"
                                      onMouseClicked="#handleHistorySelected"
                                      style="-fx-border-color: #e8e8c8;
                                             -fx-border-radius: 8;
                                             -fx-font-size: 13px;"/>
                            <Label fx:id="historyStatus"
                                   text=""
                                   wrapText="true"
                                   style="-fx-text-fill: #7a7a5a;
                                          -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox spacing="10"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 12;
                                     -fx-padding: 14;
                                     -fx-border-color: #d8d8b8;
                                     -fx-border-radius: 12;
                                     -fx-border-width: 1;">
                            <Label text="Delivery Details"
                                   style="-fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #2D2D2D;"/>
                            <TextArea fx:id="historyDetailArea"
                                      VBox.vgrow="ALWAYS"
                                      editable="false"
                                      wrapText="true"
                                      style="-fx-font-family: Consolas;
                                             -fx-font-size: 12px;
                                             -fx-border-color: #e8e8c8;
                                             -fx-border-radius: 8;"/>
                        </VBox>
                    </items>
                </SplitPane>
            </VBox>

            <!-- PROFILE PANEL -->
            <VBox fx:id="driverProfilePanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <Label text="Driver Profile"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2D2D2D;"/>
                <VBox spacing="0"
                      style="-fx-background-color: #F5F5DC;">
                    <VBox spacing="16"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 28;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 14;
                                 -fx-border-width: 1;
                                 -fx-max-width: 520;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🚗"
                                   style="-fx-font-size: 32px;"/>
                            <Label text="Driver Information"
                                   style="-fx-font-size: 16px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #2D2D2D;"/>
                        </HBox>
                        <Separator style="-fx-background-color: #e8e8c8;"/>
                        <TextArea fx:id="profileArea"
                                  prefHeight="200"
                                  editable="false"
                                  style="-fx-font-size: 13px;
                                         -fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;
                                         -fx-background-radius: 8;"/>
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Logout"
                                    onAction="#handleLogout"
                                    style="-fx-background-color: #FF7518;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;
                                           -fx-font-size: 13px;
                                           -fx-padding: 10 18;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

            <!-- FEEDBACK PANEL -->
            <VBox fx:id="driverFeedbackPanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="My Feedback"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <Label text="Feedback received from customers on your deliveries."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #7a7a5a;"/>
                    </VBox>
                    <Label fx:id="driverFeedbackCountLabel"
                           style="-fx-font-size: 12px; -fx-text-fill: #7a7a5a;"/>
                </HBox>
                <VBox spacing="10"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-padding: 14;
                             -fx-border-color: #d8d8b8;
                             -fx-border-radius: 12;
                             -fx-border-width: 1;"
                      VBox.vgrow="ALWAYS">
                    <ListView fx:id="driverFeedbackListView"
                              VBox.vgrow="ALWAYS"
                              style="-fx-border-color: #e8e8c8;
                                     -fx-border-radius: 8;
                                     -fx-font-size: 13px;"/>
                    <Label fx:id="driverFeedbackStatus"
                           text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #7a7a5a;"/>
                </VBox>
            </VBox>

        </StackPane>
    </center>

    <!-- ── BOTTOM NAV BAR ─────────────────────────────────────────────── -->
    <bottom>
        <HBox style="-fx-background-color: white;
                     -fx-border-color: #d8d8b8;
                     -fx-border-width: 1 0 0 0;">
            <Button fx:id="requestsNavButton"
                    text="📬  Requests"
                    onAction="#goRequests"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #FF7518;
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button fx:id="activeNavButton"
                    text="🚚  Active"
                    onAction="#goActive"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button fx:id="historyNavButton"
                    text="📋  History"
                    onAction="#goHistory"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button fx:id="profileNavButton"
                    text="👤  Profile"
                    onAction="#goProfile"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button fx:id="feedbackNavButton"
                    text="💬  Feedback"
                    onAction="#goFeedback"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
        </HBox>
    </bottom>

</BorderPane>
