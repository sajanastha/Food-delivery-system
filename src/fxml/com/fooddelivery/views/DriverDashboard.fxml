<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fooddelivery.DriverDashboardController"
            prefWidth="1120" prefHeight="760"
            style="-fx-background-color: #F5F5DC;">

    <!-- ── TOP HEADER ───────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #FF7518;
                     -fx-padding: 14 24;">
            <Label text="🚗 Driver Portal"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
            <Separator orientation="VERTICAL"
                       style="-fx-background-color: rgba(255,255,255,0.4);"/>
            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: rgba(255,255,255,0.88);
                          -fx-font-size: 13px;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="availabilityLabel"
                   style="-fx-text-fill: white;
                          -fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-background-color: rgba(0,0,0,0.18);
                          -fx-background-radius: 20;
                          -fx-padding: 4 12;"/>
            <CheckBox fx:id="availabilityToggle"
                      text="Available"
                      onAction="#handleAvailabilityChanged"
                      style="-fx-text-fill: white;
                             -fx-font-size: 12px;"/>
            <Button text="Refresh"
                    onAction="#handleRefresh"
                    style="-fx-background-color: rgba(255,255,255,0.18);
                           -fx-text-fill: white;
                           -fx-background-radius: 8;
                           -fx-padding: 6 14;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ── CONTENT ───────────────────────────────────────────────────── -->
    <center>
        <StackPane>

            <!-- REQUESTS PANEL -->
            <VBox fx:id="requestsPanel" spacing="14"
                  style="-fx-padding: 18;">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="3">
                        <Label text="Delivery Requests"
                               style="-fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <Label text="Available orders waiting to be picked up."
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #7a7a5a;"/>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label fx:id="summaryLabel"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #7a7a5a;"/>
                </HBox>

                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" prefWidth="380"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Available Requests"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <ListView fx:id="requestListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="260"
                                  onMouseClicked="#handleRequestSelected"
                                  style="-fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <HBox spacing="8">
                            <Button text="✔ Accept"
                                    onAction="#handleAcceptRequest"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #4d9078;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 8;
                                           -fx-padding: 10 14;
                                           -fx-cursor: hand;"/>
                            <Button text="Skip"
                                    onAction="#handleRejectRequest"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #fff0e0;
                                           -fx-text-fill: #c0390a;
                                           -fx-border-color: #FF7518;
                                           -fx-border-radius: 8;
                                           -fx-background-radius: 8;
                                           -fx-font-weight: bold;
                                           -fx-padding: 10 14;
                                           -fx-cursor: hand;"/>
                        </HBox>
                        <Label fx:id="requestStatus"
                               text=""
                               wrapText="true"
                               style="-fx-text-fill: #7a7a5a;
                                      -fx-font-size: 12px;"/>
                    </VBox>

                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Request Details"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <TextArea fx:id="requestDetailArea"
                                  VBox.vgrow="ALWAYS"
                                  editable="false"
                                  wrapText="true"
                                  promptText="Select a request to see details..."
                                  style="-fx-font-family: Consolas;
                                         -fx-font-size: 12px;
                                         -fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ACTIVE PANEL -->
            <VBox fx:id="activePanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <VBox spacing="3">
                    <Label text="Current Delivery"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #2D2D2D;"/>
                    <Label text="Track your active delivery and update status."
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #7a7a5a;"/>
                </VBox>

                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" prefWidth="380"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Active Deliveries"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <ListView fx:id="activeDeliveryListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="260"
                                  onMouseClicked="#handleActiveSelected"
                                  style="-fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <HBox spacing="8">
                            <Button text="✔ Mark Delivered"
                                    onAction="#handleMarkDelivered"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #4d9078;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 8;
                                           -fx-padding: 10 14;
                                           -fx-cursor: hand;"/>
                            <Button text="Cancel"
                                    onAction="#handleCancelDelivery"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #fff0e0;
                                           -fx-text-fill: #c0390a;
                                           -fx-border-color: #FF7518;
                                           -fx-border-radius: 8;
                                           -fx-background-radius: 8;
                                           -fx-font-weight: bold;
                                           -fx-padding: 10 14;
                                           -fx-cursor: hand;"/>
                        </HBox>
                        <Label fx:id="activeStatus"
                               text=""
                               wrapText="true"
                               style="-fx-text-fill: #7a7a5a;
                                      -fx-font-size: 12px;"/>
                    </VBox>

                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 16;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <Label text="Delivery Details"
                               style="-fx-font-size: 13px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #2D2D2D;"/>
                        <TextArea fx:id="activeDetailArea"
                                  VBox.vgrow="ALWAYS"
                                  editable="false"
                                  wrapText="true"
                                  promptText="Select an active delivery..."
                                  style="-fx-font-family: Consolas;
                                         -fx-font-size: 12px;
                                         -fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- HISTORY PANEL -->
            <VBox fx:id="driverHistoryPanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <VBox spacing="3">
                    <Label text="Delivery History"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #2D2D2D;"/>
                    <Label text="All your completed and cancelled deliveries."
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #7a7a5a;"/>
                </VBox>

                <SplitPane dividerPositions="0.45"
                           VBox.vgrow="ALWAYS">
                    <items>
                        <VBox spacing="10"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 12;
                                     -fx-padding: 14;
                                     -fx-border-color: #d8d8b8;
                                     -fx-border-radius: 12;
                                     -fx-border-width: 1;">
                            <Label text="Past Deliveries"
                                   style="-fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #2D2D2D;"/>
                            <ListView fx:id="historyListView"
                                      VBox.vgrow="ALWAYS"
                                      onMouseClicked="#handleHistorySelected"
                                      style="-fx-border-color: #e8e8c8;
                                             -fx-border-radius: 8;
                                             -fx-font-size: 13px;"/>
                            <Label fx:id="historyStatus"
                                   text=""
                                   wrapText="true"
                                   style="-fx-text-fill: #7a7a5a;
                                          -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox spacing="10"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 12;
                                     -fx-padding: 14;
                                     -fx-border-color: #d8d8b8;
                                     -fx-border-radius: 12;
                                     -fx-border-width: 1;">
                            <Label text="Delivery Details"
                                   style="-fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #2D2D2D;"/>
                            <TextArea fx:id="historyDetailArea"
                                      VBox.vgrow="ALWAYS"
                                      editable="false"
                                      wrapText="true"
                                      style="-fx-font-family: Consolas;
                                             -fx-font-size: 12px;
                                             -fx-border-color: #e8e8c8;
                                             -fx-border-radius: 8;"/>
                        </VBox>
                    </items>
                </SplitPane>
            </VBox>

            <!-- PROFILE PANEL -->
            <VBox fx:id="driverProfilePanel" spacing="14"
                  visible="false" managed="false"
                  style="-fx-padding: 18;">
                <Label text="Driver Profile"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2D2D2D;"/>
                <VBox spacing="0"
                      style="-fx-background-color: #F5F5DC;">
                    <VBox spacing="16"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 28;
                                 -fx-border-color: #d8d8b8;
                                 -fx-border-radius: 14;
                                 -fx-border-width: 1;
                                 -fx-max-width: 520;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🚗"
                                   style="-fx-font-size: 32px;"/>
                            <Label text="Driver Information"
                                   style="-fx-font-size: 16px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #2D2D2D;"/>
                        </HBox>
                        <Separator style="-fx-background-color: #e8e8c8;"/>
                        <TextArea fx:id="profileArea"
                                  prefHeight="200"
                                  editable="false"
                                  style="-fx-font-size: 13px;
                                         -fx-border-color: #e8e8c8;
                                         -fx-border-radius: 8;
                                         -fx-background-radius: 8;"/>
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Logout"
                                    onAction="#handleLogout"
                                    style="-fx-background-color: #FF7518;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;
                                           -fx-font-size: 13px;
                                           -fx-padding: 10 18;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

        </StackPane>
    </center>

    <!-- ── BOTTOM NAV BAR ─────────────────────────────────────────────── -->
    <bottom>
        <HBox style="-fx-background-color: white;
                     -fx-border-color: #d8d8b8;
                     -fx-border-width: 1 0 0 0;">
            <Button text="📬  Requests"
                    onAction="#goRequests"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #FF7518;
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button text="🚚  Active"
                    onAction="#goActive"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button text="📋  History"
                    onAction="#goHistory"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
            <Button text="👤  Profile"
                    onAction="#goProfile"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    prefHeight="54"
                    style="-fx-background-color: #F5F5DC;
                           -fx-text-fill: #555;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-background-radius: 0;"/>
        </HBox>
    </bottom>

</BorderPane>
